{
  "name": "@cowork/worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema ../api/prisma/schema.prisma && tsc -p tsconfig.json",
    "build:only": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.25.2",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.8",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}
