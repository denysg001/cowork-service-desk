generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
  MEMBER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobState {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(MEMBER)
  version      Int       @default(0)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  tickets      Ticket[]  @relation("TicketRequester")
  assigned     Ticket[]  @relation("TicketAssignee")
  auditLogs    AuditLog[]
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  refreshHash  String
  userAgent    String?
  ipAddress    String?
  revokedAt    DateTime?
  expiresAt     DateTime
  rotatedFromId String?   @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([refreshHash])
}

model Ticket {
  id          String         @id @default(uuid()) @db.Uuid
  number      Int            @unique @default(autoincrement())
  title       String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  location    String
  requesterId String         @db.Uuid
  assigneeId  String?        @db.Uuid
  version     Int            @default(0)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  requester User  @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee  User? @relation("TicketAssignee", fields: [assigneeId], references: [id])
  events    TicketEvent[]
  attachments Attachment[]

  @@index([status, createdAt, id])
  @@index([priority, createdAt, id])
  @@index([deletedAt])
}

model TicketEvent {
  id            String   @id @default(uuid()) @db.Uuid
  ticketId      String   @db.Uuid
  actorId       String?  @db.Uuid
  type          String
  payload       Json
  correlationId String
  createdAt     DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt, id])
}

model Attachment {
  id           String    @id @default(uuid()) @db.Uuid
  ticketId     String    @db.Uuid
  storageKey   String
  originalName String
  mime         String
  sizeBytes    Int
  checksum     String
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model IdempotencyKey {
  id          String    @id @default(uuid()) @db.Uuid
  key         String
  scope       String
  statusCode  Int
  response    Json
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@unique([key, scope])
  @@index([expiresAt])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorId       String?  @db.Uuid
  action        String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  correlationId String
  createdAt     DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId, createdAt])
}

model OutboxEvent {
  id            String   @id @default(uuid()) @db.Uuid
  topic         String
  payload       Json
  correlationId String
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([processedAt, createdAt])
}

model DeadLetterJob {
  id            String   @id @default(uuid()) @db.Uuid
  queue         String
  jobId         String
  name          String
  payload       Json
  reason        String
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([queue, createdAt])
}
